{
  "name": "pill-match",
  "description": "A prescription-themed Match-3 puzzle game built with Phaser 4, Vite and TypeScript.",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PlayableStories/pill-match.git"
  },
